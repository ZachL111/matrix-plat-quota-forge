{
  "repo": "matrix-plat-quota-forge",
  "language": "Java",
  "category": "Platform engineering",
  "goal": "Package a Java local lab for quota analysis with transition tables, invalid-transition tests, and documented operating limits.",
  "weights": {
    "signal": 4,
    "slack": 2,
    "confidence": 2,
    "drag": 2
  },
  "thresholds": {
    "ship": 189,
    "watch": 119
  },
  "properties": [
    "raising signal cannot reduce score",
    "raising drag cannot improve score",
    "lane labels must match configured thresholds",
    "golden fixture ids must remain unique"
  ],
  "fixture_files": [
    "fixtures/golden/scoreboard.csv",
    "fixtures/golden/lane-matrix.csv",
    "fixtures/fuzz/mutations.csv",
    "fixtures/fuzz/boundary-cases.jsonl"
  ]
}
